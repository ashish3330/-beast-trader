<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.dragon.caffeinate</string>
    <!-- Prevents idle sleep, disk sleep, and system sleep while the bot is
         running. -d also keeps display from sleeping which is intentional —
         JARVIS dashboard stays usable. To disable: launchctl bootout
         gui/<uid>/com.dragon.caffeinate -->
    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/caffeinate</string>
        <string>-dis</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>ThrottleInterval</key>
    <integer>30</integer>
    <key>StandardOutPath</key>
    <string>/Users/ashish/Documents/beast-trader/logs/caffeinate_stdout.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/ashish/Documents/beast-trader/logs/caffeinate_stderr.log</string>
</dict>
</plist>
